# ==========================================================================
# TEMPLATE — copy this file to application-secret.properties and fill in real
# values. The real application-secret.properties is git-ignored.
#   cp application-secret.properties.example application-secret.properties
# ==========================================================================

# ===== MariaDB credentials =====
spring.datasource.username=your-db-user
spring.datasource.password=your-db-password

# ===== Admin seed account (created on first startup) =====
app.admin.username=admin
app.admin.password=choose-a-strong-password

# ===== JWT signing key (HS256, must be at least 32 characters) =====
app.jwt.secret=replace-with-a-long-random-secret-at-least-32-chars
